cat > .gitignore << 'EOF'
# Terraform directories
**/.terraform/*

# State files
*.tfstate
*.tfstate.*

# Sensitive variable files - these contain secrets, never commit
*.tfvars
!example.tfvars
!backend.tfvars

# Crash logs
crash.log
crash.*.log

# OS files
.DS_Store
Thumbs.db

# Keep lock file
!.terraform.lock.hcl
EOF